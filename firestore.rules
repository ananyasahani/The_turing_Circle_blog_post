rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isModerator() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "moderator";
    }
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified;
    }
    function isNotBlocked() {
      return !exists(/databases/$(database)/documents/denylist/$(request.auth.uid));
    }

    // DRAFTS — only the author and moderators
    match /drafts/{draftId} {
      allow read: if isOwner(resource.data.authorId) || isModerator();
      allow create: if isSignedIn()
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.content is string;
      allow update: if isOwner(resource.data.authorId)
                    && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isOwner(resource.data.authorId) || isModerator();
    }

    // PUBLISHED — anyone can read, only Cloud Functions can create
    match /published/{postId} {
      allow read: if true;
      allow create: if false;   // only via Cloud Function
      allow update: if isModerator()
                    || isOwner(resource.data.authorId);
      allow delete: if false;   // only soft-delete via updating visible=false

      // COMMENTS — subcollection on each published post
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isVerified() && isNotBlocked()
                      && request.resource.data.authorId == request.auth.uid
                      && request.resource.data.content is string;
        allow update: if isOwner(resource.data.authorId)
                      && (request.time - resource.data.createdAt) < duration.value(1, 'h');
        allow delete: if isOwner(resource.data.authorId)
                      || isModerator()
                      || isOwner(get(/databases/$(database)/documents/published/$(postId)).data.authorId);
      }
    }

    // USERS
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}